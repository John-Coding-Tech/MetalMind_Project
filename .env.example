# Copy this file to .env and fill in your values.
# On Railway, DATABASE_URL is injected automatically by the Postgres plugin.

TAVILY_API_KEY=        # Required: web search enrichment (tavily.com)
GEMMA_API_KEY=         # Required: Google AI (Gemma) for AI cross-check and insights
SERPER_API_KEY=        # Required: primary web search (serper.dev)
DATABASE_URL=          # Required in production: Railway injects postgresql://... automatically
                       # Leave unset for local dev — falls back to SQLite (metalmind.db)
ENV=development        # Set to "production" on Railway to enforce DATABASE_URL requirement
